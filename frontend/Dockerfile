# Stage 1: Build Next.js assets
FROM node:20-slim AS builder

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

# Set environment variable to indicate production build
ENV NODE_ENV=production

RUN npm run build

# Stage 2: Serve Next.js standalone application
FROM node:20-slim AS runner

WORKDIR /app

# Set production env
ENV NODE_ENV=production \
    PORT=3000 \
    HOSTNAME="0.0.0.0"

# Copy standalone build outputs
COPY --from=builder /app/public ./public
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static

EXPOSE 3000

# Start server.js generated by next build standalone option
CMD ["node", "server.js"]
